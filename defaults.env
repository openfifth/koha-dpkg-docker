BRANCH="main"
KDD_BRANCH="${BRANCH:-main}"
KDD_REGISTRY="ghcr.io/openfifth/koha-dpkg-docker"
FAMILY="debian"
FAMILY_SEC="${FAMILY:-debian}-security"
MIRROR="http://deb.debian.org/${FAMILY:-debian}"
MIRROR_SEC="http://security.debian.org/${FAMILY_SEC:-debian-security}"
DISTRIBUTION="trixie"
DISTRIBUTION_SEC="${DISTRIBUTION:-trixie}-security"
KEYRING="/usr/share/keyrings/debian-archive-keyring.gpg"
SUITE="unstable"
REPO="http://debian.koha-community.org/koha-staging"
DEBIAN_FRONTEND="noninteractive"
EMAIL="hosting@openfifth.co.uk"
DEB_BUILD_OPTIONS="nocheck"
